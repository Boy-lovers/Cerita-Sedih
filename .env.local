# ======================================================================
# ENVIRONMENT VARIABLES
# Salin file ini jadi .env.local (sudah bernama .env.local) lalu isi
# API key kamu sendiri. JANGAN pernah di-commit ke git (sudah ada di
# .gitignore).
# ======================================================================

# API key Anthropic (Claude) buat fitur AI Chat di /ai
# Ambil di: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=isi_api_key_anthropic_kamu_disini

# API key YouTube Data API v3 buat fitur NachynTube di /nachyntube
# Ambil di: https://console.cloud.google.com/apis/credentials
# (aktifkan dulu "YouTube Data API v3" di Google Cloud Console)
YOUTUBE_API_KEY=isi_api_key_youtube_kamu_disini
